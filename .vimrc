set autoindent
:let mapleader=","
filetype plugin on

" colorscheme
syntax enable
set background=dark
"colorscheme solarized

:imap hh <Esc>
set number
set relativenumber
":set tabstop=4
set tabstop=4
set softtabstop=4
set shiftwidth=4
set textwidth=79
set expandtab
set autoindent
set fileformat=unix
